# Base URL của backend (nơi expose POST /auth/login).
# KHÔNG đặt ODOO_URL / ODOO_API_KEY ở đây — những biến đó chỉ dùng ở backend,
# frontend không bao giờ gọi thẳng Odoo hay cần các credential đó.

# Dev (backend chạy local):
VITE_API_BASE_URL=http://localhost:3000/api

# Prod (ví dụ):
# VITE_API_BASE_URL=https://api-mobile.19t.vn
